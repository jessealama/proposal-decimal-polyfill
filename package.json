{
    "name": "proposal-decimal",
    "version": "20260708.0.0",
    "description": "Champion-maintained polyfill for the TC39 decimal proposal",
    "main": "dist/Decimal.mjs",
    "types": "./src/Decimal.d.mts",
    "exports": {
        ".": {
            "types": "./src/Decimal.d.mts",
            "default": "./dist/Decimal.mjs"
        },
        "./package.json": "./package.json"
    },
    "c8": {
        "include": [
            "src/**"
        ]
    },
    "scripts": {
        "test": "jest",
        "prepack": "npx tsc && npm run build",
        "format": "prettier . --write",
        "lint": "prettier . --check",
        "coverage": "npx c8 npx jest",
        "build": "mkdir -p dist && esbuild src/Decimal.mjs --bundle --format=esm --outfile=dist/Decimal.mjs",
        "mutation": "stryker run"
    },
    "prettier": {
        "trailingComma": "es5",
        "tabWidth": 4,
        "semi": true,
        "singleQuote": false
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/jessealama/proposal-decimal-polyfill.git"
    },
    "type": "module",
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": "^24",
            "onFail": "error"
        }
    },
    "keywords": [
        "decimal",
        "number",
        "math",
        "floating-point"
    ],
    "author": "Jesse Alama <jesse@igalia.com>",
    "license": "BSD-2-Clause",
    "bugs": {
        "url": "https://github.com/jessealama/proposal-decimal-polyfill/issues"
    },
    "homepage": "https://github.com/jessealama/proposal-decimal-polyfill#readme",
    "devDependencies": {
        "@stryker-mutator/core": "^9.6.1",
        "bignumber.js": "^11.0.0",
        "c8": "^11.0.0",
        "decimal.js-light": "^2.5.1",
        "esbuild": "^0.28.0",
        "http-server": "^14.1.1",
        "jest": "^30.2.0",
        "jest-light-runner": "^0.8.1",
        "prettier": "^3.4.1",
        "typescript": "^6.0.3"
    }
}
